{
  "name": "@jb0xyz/create-vivere",
  "version": "0.3.0",
  "description": "Interactive project scaffolder for Vivere.",
  "homepage": "https://github.com/jb0xyz/vivere#readme",
  "bugs": "https://github.com/jb0xyz/vivere/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jb0xyz/vivere.git",
    "directory": "packages/create-vivere"
  },
  "license": "MIT",
  "author": "jb0xyz",
  "type": "module",
  "sideEffects": false,
  "engines": { "node": ">=20.11" },
  "publishConfig": { "access": "public" },
  "bin": {
    "create-vivere": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
